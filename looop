# Surface everything that needs the human ON the loop pane. No OS notifications:
# we live in tmux, so a worker that needs us pops a dedicated tmux window (see
# tmux_surface). attention.md is reserved for genuine blockers (mentions/questions
# where someone is stuck on us) — standing review-request queues are count-only
# (see goals/review-inbox.md) and must NOT land here.
surface_attention() {
  local flags att
  flags="$(babysit ls --json 2>/dev/null \
    | jq -r --arg bsd "$(bs_hint_env)" '.[] | select(.id|startswith("looop-")) | select(.note != null and .note != "")
        | "  ⚑ \(.id)\n     \(.note)\n     → \($bsd)babysit attach -s \(.id)"' 2>/dev/null || true)"
  att=""
  [ -s "$LOOOP_DATA_DIR/attention.md" ] && att="$(sed 's/^/  /' "$LOOOP_DATA_DIR/attention.md")"
  local pb=""
  [ -f "$PLAYBOOK_PROPOSED" ] && pb="  📝 PLAYBOOK change pending approval
     review:  looop playbook diff
     accept:  looop playbook approve   ·   discard:  looop playbook reject"
  [ -z "$flags" ] && [ -z "$att" ] && [ -z "$pb" ] && return 0
  log "${c_yel}${c_b}👁  NEEDS YOU${c_rst}"
  [ -n "$pb" ] && printf '%s\n' "$pb"
  [ -n "$att" ] && printf '%s\n' "$att"
  [ -n "$flags" ] && printf '%s\n' "$flags"
  tmux_surface
}

# When a worker raises a flag (babysit note), pop a tmux window attached to it,
# so a human living in tmux can't miss it — much louder than a buried log line
# or a transient OS notification. Idempotent: at most one window per flagged
# session, tracked in .tmux-surfaced; unflag→reflag pops a fresh one. The pulse
# runs detached (no $TMUX), so we target the running server's current session.
# Disable with LOOOP_TMUX_SURFACE=0. Add -d to new-window to stop it stealing focus.
tmux_surface() {
  [ "${LOOOP_TMUX_SURFACE:-1}" = "0" ] && return 0
  command -v tmux >/dev/null 2>&1 || return 0
  tmux info >/dev/null 2>&1 || return 0          # no server running → nothing to pop into
  local seen="$LOOOP_DATA_DIR/.tmux-surfaced" ids existing id wname
  ids="$(babysit ls --json 2>/dev/null \
    | jq -r '.[] | select(.id|startswith("looop-")) | select(.note != null and .note != "") | .id' 2>/dev/null || true)"
  # Prune the seen-list to only still-flagged ids, so a re-flag pops again later.
  touch "$seen"
  printf '%s\n' "$ids" | grep -Fxf "$seen" > "$seen.tmp" 2>/dev/null || : > "$seen.tmp"
  mv "$seen.tmp" "$seen"
  [ -z "$ids" ] && return 0
  existing="$(tmux list-windows -a -F '#{window_name}' 2>/dev/null || true)"
  while IFS= read -r id; do
    [ -z "$id" ] && continue
    grep -qxF "$id" "$seen" 2>/dev/null && continue              # already surfaced this flag
    wname="⚑${id#looop-}"
    printf '%s\n' "$existing" | grep -qxF "$wname" && continue   # window already open
    if tmux new-window -n "$wname" "$(bs_hint_env)babysit attach -s '$id'" 2>/dev/null; then
      printf '%s\n' "$id" >> "$seen"
    fi
  done <<EOF
$ids
EOF
}

# ---- world hash: skip the AI when nothing changed ---------------------------
world_hash() {
  {
    # hash each input behind a path marker so file boundaries are unambiguous
    # (and an empty glob just contributes nothing instead of blocking on stdin)
    local f
    for f in "$PLAYBOOK" "$GOALS_DIR"/*.md; do
      [ -f "$f" ] || continue
      printf '@@ %s\n' "${f#"$LOOOP_DATA_DIR"/}"; cat "$f"
    done
    # Sensor snapshots: hash only the wake SIGNAL, not volatile detail. A sensor
    # may split its reading into {"signal":…,"detail":…}; only .signal feeds the
    # hash, so flapping counts / timestamps parked under .detail don't burn an
    # LLM call — while the FULL object still reaches the prompt as context. A
    # sensor with no "signal" key is hashed whole (back-compat: the whole reading
    # is the signal). jq -S canonicalizes (sorted keys), so mere key reordering
    # never wakes the loop; non-JSON / error readings fall back to raw bytes.
    for f in "$SNAPSHOTS_DIR"/*.json; do
      [ -f "$f" ] || continue
      printf '@@ %s\n' "${f#"$LOOOP_DATA_DIR"/}"
      jq -cS 'if (type=="object" and has("signal")) then .signal else . end' "$f" 2>/dev/null || cat "$f"
    done
    # worker sessions (id prefixed 'looop-'). Hash only the STABLE signal —
    # id/state/exit_code/flag-note — NOT the ever-incrementing age column, so a
    # tick fires on a real transition (worker started / exited / raised a flag)
    # and stays idle otherwise (incl. while exited-but-unpruned sessions linger).
    babysit ls --json 2>/dev/null \
      | jq -r '.[] | select(.id|startswith("looop-")) | "\(.id) \(.state) \(.exit_code) \(.note)"' \
      || true
  } | _hash | cut -d' ' -f1
}

# ---- assemble the tick prompt ------------------------------------------------
build_prompt() {
  local focus="${1:-}"
  if [ -n "$focus" ]; then
    cat <<EOF
=== MANUAL RUN (human override) ===
The human explicitly asked you to act on the goal "$focus" RIGHT NOW. IGNORE the
normal priority order AND the "do nothing" option: make the single most important
move FOR THAT GOAL this run (often: start its worker session, or a small direct
action / file edit). The PLAYBOOK, the OTHER goals, sensor readings and sessions
below are CONTEXT to inform that move — act on "$focus", not on them. Still obey
every rule & guardrail, and still append exactly ONE line to journal.md.

EOF
  fi
  cat <<EOF
You are "looop", a personal operations agent. This is one tick of a loop; your
process is disposable. Your working directory is the loop's DATA dir
($LOOOP_DATA_DIR): goals/, journal.md and sensors/ are here; edit with relative paths.

Read the PLAYBOOK, goals, sensor readings and sessions below, then make exactly
ONE move — the single most important one — and stop.

Moves:
- do a small reversible action directly (gh commands, drafts, queries)
- create / update / archive a goal (files in goals/; archive = move to goals/archive/)
- write or adjust an sensor script in sensors/ when you need a new view of the
  world; it runs from next tick. CONTRACT: print ONE small, NORMALIZED JSON
  object to stdout (capped ~8KB — it is cat'd into this prompt every beat, so a
  raw dump inflates context + cost). To avoid waking the loop on noise, split
  volatile fields out: {"signal":{… only the state that should trigger a move…},
  "detail":{… counts/timestamps/extra context…}} — only .signal feeds the
  change-detection hash, while the whole object still reaches this prompt.
- start a worker session for hands-on work (runs an agent under babysit, in the
  data dir):
    $LOOOP_BIN start-session <id> "<detailed prompt for the worker>"
  <id> matches the goal file name. The worker starts in the data dir; if its
  task edits CODE it must provision its OWN sandbox first (box if available, else
  git worktree) and cd in — say so in the prompt. Never edit code in the data dir.
- propose a PLAYBOOK change: write the FULL new PLAYBOOK to PLAYBOOK.proposed.md
  (NOT PLAYBOOK.md). The PLAYBOOK is the guardrail, so a change does NOT take
  effect until the HUMAN approves it (looop playbook approve); the loop keeps
  running on the current PLAYBOOK until then. NOTE: any edit you make to
  PLAYBOOK.md directly is automatically rolled back and parked as a proposal
  anyway — so just write PLAYBOOK.proposed.md. If a proposal is already pending
  (flagged below), do NOT add another.
- do nothing (a valid move when nothing needs doing)

Optional — set WHEN the next beat runs: you may write a single integer (seconds)
to .next-interval (one-shot, clamped 5..3600). Use your judgment per the PLAYBOOK:
tighten to keep working when a backlog is piling up, or widen when it's been
quiet a long while (spare cost / external APIs). Write nothing to keep the
default rhythm. This does NOT count as your one move.

After your move, append exactly ONE line to journal.md. Copy the timestamp
prefix below VERBATIM — it is already in this host's local time ($(date '+%Z')).
Do NOT recompute it, do NOT convert to UTC, do NOT use your own clock:
  - $(date '+%Y-%m-%d %H:%M') <what you did and why>
(For reference, the current local time right now is $(date '+%Y-%m-%d %H:%M %Z').)

=== PLAYBOOK ===
$(cat "$PLAYBOOK")
$([ -f "$PLAYBOOK_PROPOSED" ] && printf '\n=== ⚠ A PLAYBOOK CHANGE IS ALREADY PENDING HUMAN APPROVAL ===\nA previous tick proposed an edit; it is awaiting the human and is NOT yet active\n(the PLAYBOOK above is still the one in force). Do NOT propose another PLAYBOOK\nchange this tick — pick a different move or do nothing.\n')

=== GOALS ===
EOF
  local g had=0
  for g in "$GOALS_DIR"/*.md; do
    had=1
    printf -- '--- %s\n' "$(basename "$g")"
    cat "$g"
    printf '\n'
  done
  [ "$had" -eq 0 ] && echo "(no goals yet)"

  echo
  echo "=== SENSOR READINGS ==="
  local o
  for o in "$SNAPSHOTS_DIR"/sensor-*.json; do
    [ -e "$o" ] || continue
    printf -- '--- %s\n' "$(basename "$o")"
    cat "$o"
    printf '\n'
  done

  echo
  echo "=== WORKER SESSIONS (babysit; ⚑note = the worker is waiting for you) ==="
  babysit ls --json 2>/dev/null \
    | jq -r '.[] | select(.id|startswith("looop-"))
        | "- \(.id) [\(.state)" + (if .exit_code != null then " exit \(.exit_code)" else "" end) + "]"
          + (if .note then "  ⚑ \(.note)" else "" end)' \
    | grep . || echo "(none)"

  echo
  echo "=== WORKER CLAIMS (live leases — a name with a claim here is OWNED by a worker; do NOT act on it yourself, the owner is reconciling it) ==="
  # reap_stale_claims has already run this beat, so every file here is a LIVE
  # lease (its session is alive). The pulse shows the raw claim; the PLAYBOOK
  # decides what the <name> means and how to honor ownership.
  { for o in "$CLAIMS_DIR"/*.json; do
      [ -e "$o" ] || continue
      printf -- '- %s: %s\n' "$(basename "${o%.json}")" "$(tr -d '\n' < "$o")"
    done; } | grep . || echo "(none)"

  echo
  echo "=== RECENT JOURNAL ==="
  tail -20 "$JOURNAL" 2>/dev/null || echo "(empty)"
}

# ---- worker leases (claims) --------------------------------------------------
# A claim is claims/<name>.json carrying a .session field. A worker writes one to
# announce "I own <name>" (the PLAYBOOK decides what <name> means — e.g. a repo)
# and deletes it when done. The pulse only does the DETERMINISTIC half of the
# lease: reap claims whose session is no longer alive (crash-safety), so the AI
# never has to remember to clean up a corpse's lease. It never interprets the
# claim body — ownership judgment stays in the PLAYBOOK.
reap_stale_claims() {
  [ -d "$CLAIMS_DIR" ] || return 0
  local alive cf sess
  alive="$(babysit ls --json 2>/dev/null | jq -r '.[] | select(.alive==true) | .id' 2>/dev/null)"
  for cf in "$CLAIMS_DIR"/*.json; do
    [ -e "$cf" ] || continue
    sess="$(jq -r '.session // empty' "$cf" 2>/dev/null)"
    if [ -z "$sess" ] || ! printf '%s\n' "$alive" | grep -qxF "$sess"; then
      rm -f "$cf"
      log "  ${c_dim}reaped stale claim $(basename "$cf") (session '${sess:-?}' not alive)${c_rst}"
    fi
  done
}

# ---- PLAYBOOK approval gate --------------------------------------------------
# The PLAYBOOK is the guardrail; a change to it must be HUMAN-approved before it
# can steer any tick. The shell enforces this DETERMINISTICALLY (it does not
# trust the AI to ask): it tells WHO changed PLAYBOOK.md by WHEN it changed.
#   .PLAYBOOK.approved  = the last human-approved bytes (the baseline the loop runs on).
#   PLAYBOOK.proposed.md = the AI's pending change, parked for review.
# A change seen while the loop is IDLE (between beats) is the human's — that edit
# IS the approval (README: "edit PLAYBOOK.md, it takes effect next tick"). A
# change made DURING the AI's run is the AI's proposal — rolled back and parked.
# Both halves are pure file compare/copy (no judgment) so RULE 2 holds.

# Before the AI runs: ensure a baseline exists and fold any idle/human edit into
# it (idle change == approved). PLAYBOOK.md itself is never altered here.
playbook_gate_pre() {
  [ -f "$PLAYBOOK" ] || return 0
  if [ ! -f "$PLAYBOOK_APPROVED" ]; then
    cp "$PLAYBOOK" "$PLAYBOOK_APPROVED"   # first run: the seeded/onboarded PLAYBOOK is the baseline
    return 0
  fi
  # Differs while the AI is NOT running → a human edited it between beats: adopt.
  cmp -s "$PLAYBOOK" "$PLAYBOOK_APPROVED" || cp "$PLAYBOOK" "$PLAYBOOK_APPROVED"
}

# After the AI runs: if it touched PLAYBOOK.md, that is a PROPOSAL, not a live
# change. Stash it in PLAYBOOK.proposed.md and restore the approved baseline, so
# the guardrail the loop steers by never shifts without a human. (If the AI took
# the happy path and wrote PLAYBOOK.proposed.md directly, PLAYBOOK.md is
# unchanged and this is a no-op — the proposal still surfaces.)
playbook_gate_post() {
  [ -f "$PLAYBOOK_APPROVED" ] || return 0
  [ -f "$PLAYBOOK" ] || return 0
  if ! cmp -s "$PLAYBOOK" "$PLAYBOOK_APPROVED"; then
    cp "$PLAYBOOK" "$PLAYBOOK_PROPOSED"   # park the AI's version for human review
    cp "$PLAYBOOK_APPROVED" "$PLAYBOOK"   # roll the live PLAYBOOK back to the approved baseline
    log "  ${c_yel}📝 the tick proposed a PLAYBOOK change — parked for approval (looop playbook diff)${c_rst}"
  fi
}

# ---- one beat ----------------------------------------------------------------
TICK_ACTED=0
tick() {
  TICK_ACTED=0
  ensure_dirs
  playbook_gate_pre   # adopt any idle/human PLAYBOOK edit as the new approved baseline

  if [ -f "$LOOOP_DATA_DIR/paused" ]; then
    log "paused ($LOOOP_DATA_DIR/paused exists) — skipping"
    return 0
  fi

  # 0. housekeeping: reap finished worker corpses (deterministic, no AI). Workers
  #    self-kill when fully done (see the WORKER CONTRACT in start-session), which
  #    turns them into dead sessions; prune clears them so babysit ls stays clean.
  babysit prune >/dev/null 2>&1 || true
  reap_stale_claims   # drop leases held by sessions that are no longer alive

  # 1. sense the world (run sensors) — each prints one JSON snapshot; log each
  #    one with its duration so a slow sensor (gh/linear/…) is visible.
  local s name t0 n
  # level-triggered (RULE 6): wipe last tick's snapshots so a deleted/renamed
  # sensor can't leave a stale reading behind — the snapshot set always equals
  # the current sensor set.
  rm -rf "$SNAPSHOTS_DIR"; mkdir -p "$SNAPSHOTS_DIR"
  # shellcheck disable=SC2012  # glob already expands paths safely; we only count lines
  n=$(ls "$SENSORS_DIR"/*.sh 2>/dev/null | wc -l | tr -d ' ')
  if [ "$n" -gt 0 ]; then log "${c_b}sensing the world${c_rst} ${c_dim}($n sensors)${c_rst}…"; fi
  for s in "$SENSORS_DIR"/*.sh; do
    [ -e "$s" ] || continue
    name="$(basename "${s%.sh}")"
    t0=$SECONDS
    if _sensor_exec "$s" "$SNAPSHOTS_DIR/sensor-$name.json" "$SNAPSHOTS_DIR/sensor-$name.err"; then
      log "  ${c_grn}✓${c_rst} $name ${c_dim}($((SECONDS - t0))s)${c_rst}"
    else
      local rc=$?
      [ "$rc" -eq 124 ] && printf 'sensor timed out after %ss (LOOOP_SENSOR_TIMEOUT)\n' "${LOOOP_SENSOR_TIMEOUT:-60}" >> "$SNAPSHOTS_DIR/sensor-$name.err"
      log "  ${c_red}✗ $name FAILED${c_rst} ${c_dim}($((SECONDS - t0))s) — see snapshots/sensor-$name.err${c_rst}"
    fi
    # drop the empty .err a successful sensor leaves behind (keep only real errors)
    [ -s "$SNAPSHOTS_DIR/sensor-$name.err" ] || rm -f "$SNAPSHOTS_DIR/sensor-$name.err"
  done

  # 2. skip if the world is unchanged (cheap: no AI call)
  local hash
  hash="$(world_hash)"
  if [ "$hash" = "$(cat "$LOOOP_DATA_DIR/.last-tick-hash" 2>/dev/null || true)" ]; then
    log "${c_dim}world unchanged — nothing to decide; skipping (no AI call)${c_rst}"
    return 0
  fi

  # 3. hand everything to the AI for one move
  local runner tick_cmd prompt cost_id run_dir
  runner="$(cfg '.default')"
  tick_cmd="$(jq -r --arg r "$runner" '.runners[$r].tick' "$CONFIG")"
  # Archive this beat's exact prompt + output under runs/<id>/ so it is
  # REPLAYABLE later ("what did the AI see and decide at 14:32?"). The run id
  # doubles as the cost-ledger id, tying spend to a replayable transcript.
  cost_id="tick-$(date +%Y%m%d-%H%M%S)"
  run_dir="$RUNS_DIR/$cost_id"; mkdir -p "$run_dir"
  prompt="$run_dir/prompt.md"
  build_prompt > "$prompt"

  t0=$SECONDS
  log "${c_cyan}╭─ ${c_b}deciding the one move${c_rst}${c_cyan} ─${c_rst} ${c_dim}$runner is thinking (its output follows)…${c_rst}"
  export LOOOP_COST_KIND=tick LOOOP_COST_RUNNER="$runner" LOOOP_COST_ID="$cost_id"
  if ( cd "$LOOOP_DATA_DIR" && eval "$tick_cmd" < "$prompt" ) 2>&1 | ts_prefix "${c_cyan}│${c_rst} " | tee "$run_dir/output.log" "$LOOOP_DATA_DIR/tick.log"; then
    printf '%s\n' "$hash" > "$LOOOP_DATA_DIR/.last-tick-hash"
    TICK_ACTED=1
    log "${c_cyan}╰─ ${c_grn}✓ decided${c_rst} ${c_dim}in $((SECONDS - t0))s · journal: $(tail -1 "$JOURNAL" 2>/dev/null || echo '(no line)')${c_rst}"
  else
    log "${c_cyan}╰─ ${c_red}✗ tick FAILED${c_rst} ${c_dim}after $((SECONDS - t0))s (replay: $run_dir)${c_rst}"
  fi
  playbook_gate_post  # a PLAYBOOK edit by the AI is a proposal, not a live change
  _prune_runs
  surface_attention
}

# ---- a single beat (debug / cron) -------------------------------------------
# Runs exactly one tick and exits. Refuses if the pulse (or another one-shot)
# holds a live lock, so it never double-acts against a running `looop run`.
cmd_tick() {
  if [ -d "$LOCK" ]; then
    local oldpid; oldpid="$(cat "$LOCK/pid" 2>/dev/null || true)"
    if [ -n "$oldpid" ] && kill -0 "$oldpid" 2>/dev/null; then
      echo "looop: pulse already running (pid $oldpid) — it ticks on its own" >&2
      exit 1
    fi
  fi
  tick
}

# ---- the pulse (default subcommand) -----------------------------------------
cmd_run() {
  ensure_dirs
  # Tick cadence. Resolution order per knob: env var > config > default.
  #   config: ~/.config/looop.json -> .interval / .busy_interval / .active_interval
  # A single "interval" in config governs all three states (flat cadence);
  # busy_interval / active_interval default to it but can be set to restore a
  # tiered rhythm. Default is a flat 60s everywhere.
  local INTERVAL="${LOOOP_INTERVAL:-$(cfg_or '.interval' 60)}"
  local BUSY_INTERVAL="${LOOOP_BUSY_INTERVAL:-$(cfg_or '.busy_interval' "$INTERVAL")}"
  # While any worker is in flight we re-observe even when a tick did nothing:
  # workers exit / resolve threads / free a cap slot at any moment. The
  # world_hash skip still suppresses the AI call when nothing actually changed,
  # so a short active cadence only costs cheap sensor re-runs — never idle AI spend.
  local ACTIVE_INTERVAL="${LOOOP_ACTIVE_INTERVAL:-$(cfg_or '.active_interval' "$INTERVAL")}"

  # single-instance lock (mkdir-based; macOS has no flock)
  if ! mkdir "$LOCK" 2>/dev/null; then
    local oldpid; oldpid="$(cat "$LOCK/pid" 2>/dev/null || true)"
    if [ -n "$oldpid" ] && kill -0 "$oldpid" 2>/dev/null; then
      echo "looop: already running (pid $oldpid)" >&2; exit 1
    fi
    # Stale lock (owner is gone): reclaim it. mkdir is the atomic arbiter — if a
    # second pulse races us through the same stale-lock path, exactly one mkdir
    # wins; the loser must exit rather than run lockless (would double-act).
    rm -rf "$LOCK"
    mkdir "$LOCK" 2>/dev/null || { echo "looop: lost the lock race — another pulse started; exiting" >&2; exit 1; }
  fi
  printf '%s\n' "$$" > "$LOCK/pid"
  trap 'rm -rf "$LOCK"' EXIT

  log "${c_b}looop started${c_rst} ${c_dim}(idle ${INTERVAL}s / busy ${BUSY_INTERVAL}s, runner $(cfg '.default' 2>/dev/null || echo '?'))${c_rst}"
  [ -n "${BABYSIT_DIR:-}" ] && log "${c_dim}profile fleet: BABYSIT_DIR=$BABYSIT_DIR (attach with: BABYSIT_DIR=$BABYSIT_DIR babysit ls)${c_rst}"
  while true; do
    tick
    # default cadence (tiered): acted → busy; workers in flight → active; else idle
    local want
    if [ "$TICK_ACTED" -eq 1 ]; then
      want="$BUSY_INTERVAL"          # acted: re-evaluate promptly
    elif babysit ls --json 2>/dev/null \
         | jq -e '[.[] | select((.id|startswith("looop-")) and .alive==true)] | length > 0' >/dev/null 2>&1; then
      want="$ACTIVE_INTERVAL"        # workers in flight: poll to fill freed slots
    else
      want="$INTERVAL"              # truly quiescent: back off, spare external APIs
    fi
    # The tick may drop a one-shot integer (seconds) into .next-interval to set
    # WHEN the next beat runs; the AI decides (per the PLAYBOOK) — e.g. widen when
    # it's been quiet a long while, tighten when a backlog is piling up. The shell
    # only consumes it and clamps to a sane range so a bad value can't wedge
    # (0s busy-spin) or strand (hours asleep) the loop.
    local reqf="$LOOOP_DATA_DIR/.next-interval" req
    if [ -s "$reqf" ]; then
      req="$(tr -dc '0-9' < "$reqf")"; rm -f "$reqf"
      if [ -n "$req" ]; then
        [ "$req" -lt 5 ] && req=5
        [ "$req" -gt 3600 ] && req=3600
        log "${c_dim}next beat in ${req}s (AI cadence; default ${want}s)${c_rst}"
        want="$req"
      fi
    fi
    sleep "$want"
  done
}

# ---- manual one-shot: run a single goal NOW ---------------------------------
# looop run <goal-id> — force ONE goal-focused move immediately. Unlike a normal
# tick this bypasses the priority order AND the world-unchanged skip, and it does
# NOT refuse while the pulse is running (explicit human override; start-session
# still guards against double-spawning a live worker). <goal-id> must exist in
# goals/ (or goals/archive/) — it is the goal file's basename without .md.
cmd_run_goal() {
  ensure_dirs
  local id="$1"
  local gf="$GOALS_DIR/$id.md"
  [ -f "$gf" ] || gf="$GOALS_DIR/archive/$id.md"
  if [ ! -f "$gf" ]; then
    echo "looop run: no such goal '$id' (looked in goals/ and goals/archive/)" >&2
    echo "available goals:" >&2
    # shellcheck disable=SC2012  # display-only listing; glob handles filenames
    ( cd "$GOALS_DIR" 2>/dev/null && ls ./*.md 2>/dev/null | sed 's#\.md$##;s#^\./#  #' ) >&2
    exit 1
  fi

  if [ -d "$LOCK" ]; then
    local p; p="$(cat "$LOCK/pid" 2>/dev/null || true)"
    if [ -n "$p" ] && kill -0 "$p" 2>/dev/null; then
      log "${c_yel}note:${c_rst} pulse is running (pid $p) — running goal '$id' anyway ${c_dim}(manual override)${c_rst}"
    fi
  fi

  babysit prune >/dev/null 2>&1 || true
  reap_stale_claims   # drop leases held by sessions that are no longer alive
  playbook_gate_pre   # adopt any idle/human PLAYBOOK edit before this run's AI move

  # A manual run does NOT refuse while the pulse is running (explicit override),
  # so it must NOT share the pulse's snapshots/ dir: a concurrent pulse tick
  # could wipe/read it mid-flight and the two would tear each other's readings.
  # Sense into a private temp dir instead (dynamic scoping makes build_prompt
  # below pick this up). Cleaned on exit even if the run aborts under set -e.
  local SNAPSHOTS_DIR
  SNAPSHOTS_DIR="$(mktemp -d "${TMPDIR:-/tmp}/looop-run.XXXXXX")"
  trap 'rm -rf "$SNAPSHOTS_DIR"' EXIT

  # fresh sensors so the move reflects the current world (same as a tick)
  local s name
  rm -rf "$SNAPSHOTS_DIR"; mkdir -p "$SNAPSHOTS_DIR"   # same level-triggered wipe as a tick
  for s in "$SENSORS_DIR"/*.sh; do
    [ -e "$s" ] || continue
    name="$(basename "${s%.sh}")"
    _sensor_exec "$s" "$SNAPSHOTS_DIR/sensor-$name.json" "$SNAPSHOTS_DIR/sensor-$name.err" || true
    [ -s "$SNAPSHOTS_DIR/sensor-$name.err" ] || rm -f "$SNAPSHOTS_DIR/sensor-$name.err"
  done

  local runner tick_cmd prompt t0 run_id run_dir
  runner="$(cfg '.default')"
  tick_cmd="$(jq -r --arg r "$runner" '.runners[$r].tick' "$CONFIG")"
  # Archive this manual run's prompt + output for replay, same as a tick. The
  # cost id stays the goal id (spend is attributed per goal); the archive id is
  # timestamped so repeated manual runs of one goal don't clobber each other.
  run_id="run-$id-$(date +%Y%m%d-%H%M%S)"
  run_dir="$RUNS_DIR/$run_id"; mkdir -p "$run_dir"
  prompt="$run_dir/prompt.md"
  build_prompt "$id" > "$prompt"
  t0=$SECONDS
  log "${c_cyan}${c_b}manual run — goal '$id'${c_rst} ${c_dim}($runner is thinking; its output follows)${c_rst}…"
  log "${c_dim}┌─ $runner ──────────────────────────────────────${c_rst}"
  export LOOOP_COST_KIND=goal LOOOP_COST_RUNNER="$runner" LOOOP_COST_ID="$id"
  ( cd "$LOOOP_DATA_DIR" && eval "$tick_cmd" < "$prompt" ) 2>&1 | ts_prefix | tee "$run_dir/output.log" "$LOOOP_DATA_DIR/tick.log"
  log "${c_dim}└────────────────────────────────────────${c_rst}"
  log "${c_grn}✓ run done${c_rst} in $((SECONDS - t0))s ${c_dim}— journal: $(tail -1 "$JOURNAL" 2>/dev/null || echo '(no line)') · replay: $run_dir${c_rst}"
  playbook_gate_post  # a PLAYBOOK edit by the AI is a proposal, not a live change
  _prune_runs
  surface_attention
}

# ---- start a worker session --------------------------------------------------
# looop start-session <id> "<prompt>" [runner]
# The pulse only LAUNCHES the agent (in the data dir) — it does NOT provision a
# workspace. If a task touches code, the worker creates its OWN sandbox first
# (box if available, else git worktree), per the PLAYBOOK. Judgment is the AI's;
# the shell just starts it.
cmd_start_session() {
  ensure_dirs
  local id="${1:?usage: looop start-session <id> <prompt> [runner]}"
  local prompt="${2:?missing prompt}"
  local runner="${3:-$(cfg '.default')}"

  local tmpl; tmpl="$(jq -r --arg r "$runner" '.runners[$r].interactive // empty' "$CONFIG")"
  [ -n "$tmpl" ] || { echo "start-session: unknown runner '$runner'" >&2; exit 1; }

  local session="looop-$id"
  if babysit status -s "$session" >/dev/null 2>&1; then
    # A session with this id exists. Only block if it's still ALIVE; a dead
    # (exited/killed) corpse just holds the id — prune it and reuse the id, so
    # "kill a worker → next tick re-spawns with the same id" just works.
    if babysit ls --json 2>/dev/null | jq -e --arg s "$session" '.[] | select(.id==$s and .alive==true)' >/dev/null 2>&1; then
      echo "start-session: session $session is already running" >&2; exit 1
    fi
    babysit prune >/dev/null 2>&1 || true
  fi

  # Prompt passed via file (avoids quoting hell; also a record of the ask).
  # Every worker gets the same contract prepended so the pulse can't forget it:
  # workers NEVER notify; when they need a human they raise a babysit flag and
  # wait. The pulse turns that flag into a tmux window the human can't miss.
  local prompt_file="$LOOOP_DATA_DIR/prompts/$session.md"
  cat > "$prompt_file" <<EOF
# ⚑ WORKER CONTRACT (auto-injected — must obey)
- Never send notifications (no terminal-notifier or any OS notification). You are
  an agent; only the pulse notifies.
- When you need a human decision / info / approval, do NOT guess — use ONLY this
  and then wait right there:
    babysit flag -s $session "<what you are waiting for / what you need to ask>"
  Once flagged, the human attaches over tmux to answer (the pulse turns the flag
  into a tmux window they can't miss).
- When the wait is resolved (you got your answer), unflag before continuing:
    babysit unflag -s $session
- When the task is 100% complete and nothing is flagged, end your own session:
    babysit kill -s $session
  (this lets the pulse prune the corpse). NEVER do this mid-task or while waiting
  on a human.
- LEASE (ONLY if the PLAYBOOK/goal tells you to claim this task) — announce
  ownership BEFORE any work so a tick or sibling can't duplicate/race you, and
  release it when done:
    mkdir -p claims && printf '{"session":"%s","name":"%s"}\n' "\$BABYSIT_SESSION_ID" "<name>" > "claims/<name>.json"
  (<name> and any extra fields are defined by the goal — e.g. one file per repo.)
  Delete claims/<name>.json the instant the task is fully done, right before the
  kill above. If you crash the pulse auto-reaps your claim; on a clean finish YOU
  delete it. NEVER sit/sleep/poll while holding a claim — act and move on.
- SINGLE-WRITER DATA DIR: the pulse (the tick AI) is the SOLE writer of the
  policy files — PLAYBOOK.md, goals/ and sensors/. By default you write ONLY to
  claims/ (your lease), reports/ (deliverables) and your own code sandbox. Do
  NOT edit PLAYBOOK/goals/sensors: a concurrent tick reads them every beat, so a
  racing writer tears the loop's state. If your task implies a policy change,
  write the proposal to reports/<id>.md and raise a flag — the human (or the
  next tick) applies it. EXCEPTION: if your task is explicitly a meta task (e.g.
  setup or playbook grooming), you MAY edit those files, but you MUST show the
  diff and `babysit flag` for human approval BEFORE writing. When unsure whether
  your task is meta, treat the data dir as read-only and propose via reports/.
- WORKSPACE: you start in the loop data dir (read-only context for you, save the
  meta exception above). If your task touches a code repo, provision your OWN
  sandbox FIRST and cd into it — never edit code in the data dir:
    • if \`box\` is available:  box new $session --repo <repo> && cd "\$(box switch $session)"
    • otherwise (git):         git -C <local-clone> worktree add /tmp/$session -b looop/$session && cd /tmp/$session
  (the PLAYBOOK names the repos and which to prefer.)
- COST: when you end your session (right before \`babysit kill\`), record this
  session's total LLM spend so the human can see it in \`looop cost\`. If you can
  determine your own USD cost for this run, log it:
    "\$LOOOP_BIN" _cost session $id $runner <usd>
  (e.g. "\$LOOOP_BIN" _cost session $id $runner 0.42). Skip only if you truly
  cannot determine the amount.
- DELIVERABLES: write any report / artifact a human will read into the data dir's
  reports/ folder (e.g. reports/<id>.md). That dir PERSISTS across ticks. NEVER
  write deliverables to snapshots/ — the pulse wipes snapshots/ on EVERY beat, so
  anything you leave there vanishes before the human sees it. Reference the
  reports/ path in your babysit flag so I know where to look.

---

EOF
  printf '%s\n' "$prompt" >> "$prompt_file"

  # The pulse always launches the agent in the data dir. Provisioning a code
  # sandbox (box / git worktree) is the WORKER's job, driven by the PLAYBOOK —
  # the shell does not think about repos.
  local workspace="$LOOOP_DATA_DIR"

  # Run the agent in the workspace under babysit, detached. bash -lc gives the
  # template shell semantics (e.g. the "$(cat prompt_file)" in looop.json).
  # FULLY detach the worker's std fds (</dev/null >/dev/null 2>&1): otherwise the
  # daemonized worker inherits and holds the caller's stdout/stderr pipe, so a
  # tick that spawns a worker can't finish until the worker exits — which would
  # defeat the whole point of detached workers (non-blocking, parallel).
  local cmd="${tmpl//\{\{prompt_file\}\}/$prompt_file}"
  ( cd "$workspace" && babysit run -d --id "$session" -- bash -lc "$cmd" ) </dev/null >/dev/null 2>&1
  echo "started $session (runner: $runner, cwd: $workspace)"
  echo "  watch: $(bs_hint_env)babysit attach -s $session"
}

# ---- cost report (looop cost) ------------------------------------------------
# Read-only view over the append-only ledger. `looop cost` = all time; add
# `today` to scope to the current UTC day, or `--json` for the raw rows.
cmd_cost() {
  local ledger="$COST_LEDGER" mode="${1:-all}"
  if [ ! -f "$ledger" ]; then
    echo "looop: no LLM cost recorded yet."
    echo "  ledger: $ledger  (written as the pulse/goals run; see 'looop help')"
    return 0
  fi
  if [ "$mode" = "--json" ]; then jq -s '.' "$ledger"; return 0; fi
  local today=""
  case "$mode" in
    all) : ;;
    today) today="$(date -u +%F)" ;;
    *) echo "usage: looop cost [today|all|--json]" >&2; return 1 ;;
  esac
  jq -rs --arg today "$today" '
    def usd: "$" + (((.*10000|round)/10000)|tostring);
    [ .[] | select(type=="object") | select($today=="" or ((.ts // "")|startswith($today))) ] as $r
    | ($r|map(.cost_usd // 0)|add // 0) as $t
    | "looop cost \u2014 \(if $today=="" then "all time" else "today ("+$today+" UTC)" end)",
      "  total: \($t|usd)  (\($r|length) calls)"
    + (if ($r|length)>0 then
        "\n  by kind:"
        + ($r|group_by(.kind)|map("\n    \(.[0].kind // "?"): \((map(.cost_usd // 0)|add)|usd)")|add)
        + "\n  by runner:"
        + ($r|group_by(.runner)|map("\n    \(.[0].runner // "?"): \((map(.cost_usd // 0)|add)|usd)")|add)
      else "" end)
  ' "$ledger"
}

# ---- PLAYBOOK proposal review (looop playbook diff|approve|reject) -----------
# The human side of the approval gate. A PLAYBOOK change proposed by the AI sits
# in PLAYBOOK.proposed.md (inert) until the human acts here. `approve` promotes
# it to the live PLAYBOOK + advances the approved baseline (so the gate won't
# re-flag it); `reject` discards it; `diff` shows what would change. With no
# pending proposal everything is a friendly no-op.
cmd_playbook() {
  ensure_dirs
  local action="${1:-diff}"
  case "$action" in
    diff)
      if [ ! -f "$PLAYBOOK_PROPOSED" ]; then echo "looop playbook: no pending change."; return 0; fi
      echo "looop playbook — pending change (approved → proposed):"
      diff -u -L "PLAYBOOK.md (approved)" -L "PLAYBOOK.proposed.md" \
        "${PLAYBOOK_APPROVED:-$PLAYBOOK}" "$PLAYBOOK_PROPOSED" || true
      echo
      echo "  approve:  looop playbook approve    reject:  looop playbook reject"
      ;;
    approve)
      [ -f "$PLAYBOOK_PROPOSED" ] || { echo "looop playbook: nothing to approve."; return 0; }
      cp "$PLAYBOOK_PROPOSED" "$PLAYBOOK"
      cp "$PLAYBOOK" "$PLAYBOOK_APPROVED"
      rm -f "$PLAYBOOK_PROPOSED"
      echo "looop playbook: approved — PLAYBOOK.md updated (takes effect next tick)."
      ;;
    reject)
      [ -f "$PLAYBOOK_PROPOSED" ] || { echo "looop playbook: nothing to reject."; return 0; }
      rm -f "$PLAYBOOK_PROPOSED"
      echo "looop playbook: rejected — proposal discarded; PLAYBOOK.md unchanged."
      ;;
    *) echo "usage: looop playbook [diff|approve|reject]" >&2; return 1 ;;
  esac
}

usage() {
  cat <<EOF
looop — personal operations loop

Usage:
  looop                          run the pulse (foreground; Ctrl-C to stop)
  looop run <goal-id>            run ONE goal NOW (manual override): a forced,
                                goal-focused move, ignoring priority order and
                                the world-unchanged skip; works while the pulse
                                runs. <goal-id> = goals/<id>.md basename.
                                e.g. looop run setup ; looop run morning-standup
  looop tick                     run a single beat and exit (debug / cron)
  looop ls [babysit ls opts]     list this profile's worker sessions (⚑ = waiting);
                                opts pass through to babysit ls, e.g.
                                looop ls --watch [--interval 2s]  (live, Ctrl-C to stop)
  looop start-session <id> "<prompt>" [runner]
                                start a worker session (used by the tick AI)
  looop cost [today|all|--json]   report LLM spend recorded in the cost ledger
                                (ticks + manual goal runs are metered
                                automatically; workers self-report via
                                'looop _cost')
  looop playbook [diff|approve|reject]
                                review a PLAYBOOK change the AI proposed. PLAYBOOK
                                edits never take effect until you approve them —
                                the loop keeps running on the current PLAYBOOK.
                                diff (default) shows it; approve applies it;
                                reject discards it. (To change judgment yourself,
                                just edit PLAYBOOK.md — that takes effect next tick.)
  looop version                  print the looop version
  looop help                     show this help

Paths (override via env LOOOP_CONFIG / LOOOP_DATA_DIR):
  config  $CONFIG
  data    $LOOOP_DATA_DIR

Worker sessions are managed by external tools (looop scopes BABYSIT_DIR to this
profile automatically; use 'looop ls' to skip the BABYSIT_DIR= prefix):
  looop ls                      list worker sessions (⚑ = waiting for you)
  looop ls --watch              watch the fleet live (= babysit ls --watch)
  $(bs_hint_env)babysit attach -s looop-<id>   enter a waiting session and talk to it

The pulse launches each worker in the data dir; if a worker needs to touch code
it provisions its OWN sandbox (box if available, else git worktree), as told by
the PLAYBOOK. looop itself has no notion of repos.

Fix judgment by editing PLAYBOOK.md (in the data dir) and committing — it takes
effect next tick. Drop a file at \$data/paused to pause the loop.
EOF
}

cmd="${1:-run}"
case "$cmd" in
  run|loop)        require_deps; shift 2>/dev/null || true
                   if [ -n "${1:-}" ]; then cmd_run_goal "$1"; else cmd_run; fi ;;
  tick)            require_deps; cmd_tick ;;
  _fmt)            cmd_fmt ;;
  cost)            shift 2>/dev/null || true; cmd_cost "$@" ;;
  _cost)           shift; record_cost "$@" ;;   # internal: workers/scripts record one call
  start-session)   require_deps; shift; cmd_start_session "$@" ;;
  ls)              require_deps; shift 2>/dev/null || true
                   exec babysit ls "$@" ;;   # BABYSIT_DIR already scoped to this profile; --watch/--interval etc. pass through
  playbook)        shift 2>/dev/null || true; cmd_playbook "$@" ;;
  version|--version|-V) echo "looop $LOOOP_VERSION" ;;
  help|-h|--help)  usage ;;
  *) echo "looop: unknown command '$cmd' (try: run, run <goal>, tick, ls, playbook, start-session, help)" >&2; exit 1 ;;
esac
